        });
        document.getElementById('eqs').innerHTML = h;
        document.querySelectorAll('select, input').forEach(el => el.oninput = calc);
    }
// 1. Hàm này để khi chọn Class (Berserker, Paladin...) thì hiện danh sách vũ khí tương ứng
function changeClass(cls) {
    const weaponSelect = document.getElementById('weaponSelect');
    weaponSelect.innerHTML = '<option value="">-- VŨ KHÍ --</option>';
    
    if (!cls || !classWeapons[cls]) return;

    // Duyệt qua các chế độ PvE, PvP, Farm của Class đó
    const modes = classWeapons[cls];
    for (let mode in modes) {
        for (let wName in modes[mode]) {
            let opt = document.createElement('option');
            // Lưu cả Class và Mode vào value để tí nữa dễ tìm dữ liệu
            opt.value = JSON.stringify({cls: cls, mode: mode, name: wName});
            opt.textContent = `[${mode}] ${wName}`;
            weaponSelect.appendChild(opt);
        }
    }
}

// 2. Hàm này để khi chọn 1 cây kiếm cụ thể, nó tự điền các dòng thuộc tính bên dưới
function autoFillWeapon(jsonVal) {
    if (!jsonVal) return;
    const info = JSON.parse(jsonVal);
    const stats = classWeapons[info.cls][info.mode][info.name];
    
    // Vũ khí luôn là box đầu tiên (index 0)
    let b = document.querySelectorAll('.box')[0];
    let selects = b.querySelectorAll('.t');
    let inputs = b.querySelectorAll('.v');

    // Reset 5 dòng thuộc tính về trống trước khi điền
    selects.forEach(s => s.value = "---");
    inputs.forEach(i => i.value = 0);

    // Điền các chỉ số đặc biệt của vũ khí vào
    stats.forEach((statText, i) => {
        if (i < selects.length) {
            let select = selects[i];
            // Nếu cái option này chưa có trong menu, thì thêm nó vào tạm thời
            if (![...select.options].some(o => o.value == statText)) {
                let opt = document.createElement('option');
                opt.value = opt.text = statText;
                select.add(opt);
            }
            select.value = statText;
            inputs[i].value = 0; // Các dòng đặc biệt thường không có chỉ số % cộng thêm
        }
    });
    calc(); // Gọi tính toán lại ngay lập tức
}

// 3. Hàm bổ trợ cho các món đồ Độc Nhất khác (Áo, Găng, Nhẫn...)
function autoFillUnique(boxIndex, itemName) {
    if (!itemName) return;
    
    const slotName = slots[boxIndex];
    const itemStats = uniqueEquip[slotName][itemName];
    if (!itemStats) return;

    let b = document.querySelectorAll('.box')[boxIndex];
    let selects = b.querySelectorAll('.t');
    let inputs = b.querySelectorAll('.v');

    // Reset 5 dòng về mặc định trước
    selects.forEach(s => s.value = "---");
    inputs.forEach(i => i.value = 0);

    // Điền dữ liệu mới
    itemStats.forEach((stat, i) => {
        if (i < selects.length) {
            let select = selects[i];
            // Kiểm tra nếu thuộc tính chưa có trong danh sách chọn thì thêm vào
            if (![...select.options].some(o => o.value == stat.t)) {
                let opt = document.createElement('option');
                opt.value = opt.text = stat.t;
                select.add(opt);
            }
            select.value = stat.t;
            inputs[i].value = stat.v;
        }
    });

    calc(); // Tính lại tổng chỉ số ngay lập tức
}
    function calc() {
        let totals = {};
        document.querySelectorAll('.box').forEach(b => {
            let ts = b.querySelectorAll('.t'), vs = b.querySelectorAll('.v');
            ts.forEach((t, i) => {
                if (t.value !== "---") {
                    totals[t.value] = (totals[t.value] || 0) + (parseFloat(vs[i].value) || 0);
                }
            });
        });
        let html = Object.entries(totals).map(([k,v]) => 
            `<div class="bg-black/40 p-2 rounded-lg border border-zinc-800/50 text-[9px]">
                <div>${k}</div><b class="text-pink-500 font-extrabold text-[11px]">${v.toFixed(1)}%</b>
             </div>`
        ).join('') || '<p class="col-span-full text-center text-zinc-600 italic">Trống...</p>';
        document.getElementById('res').innerHTML = html;
    }

    function v(type) { 
    // Bước 1: Lưu lại dữ liệu hiện tại trước khi đổi tab
    autoSave();
    
    // Bước 2: Đổi trạng thái tab
    curV = type; 
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active')); 
    document.getElementById('b-'+type).classList.add('active'); 
    
    // Bước 3: Vẽ lại giao diện mới
    render(); 
    
    // Bước 4: Nạp lại dữ liệu của hồ sơ hiện tại vào các ô vừa vẽ
    let n = document.getElementById('name').value.trim();
    if (n) {
        loadProfile(n);
    }
    
    calc(); 
}

    async function on() {
        let n = document.getElementById('name').value.trim();
        let db = JSON.parse(localStorage.getItem(DB) || '{}');
        if (!n || !db[n]) return alert('Lưu thợ săn vào máy trước đã!');
        const chu = "ABCDEFGHIJKLMNOPQRSTUVWXYZ", so = "0123456789";
        let ma = "";
        for (let i = 0; i < 4; i++) ma += chu.charAt(Math.floor(Math.random() * chu.length));
        for (let i = 0; i < 3; i++) ma += so.charAt(Math.floor(Math.random() * so.length));
        document.getElementById('ma_val').innerText = ma;
        document.getElementById('cloudModal').classList.remove('hidden');
        try {
            fetch(GOOGLE_API, {
                method: 'POST',
                mode: 'no-cors',
                body: JSON.stringify({ ma: ma, raw: JSON.stringify({ n: n, d: db[n] }) })
            });
        } catch (e) { console.log("Lưu ngầm lỗi"); }
    }

    async function nhap() {
        let ma = prompt('Nhập mã (VD: ABCD123):');
        if (!ma) return;
        ma = ma.toUpperCase().trim();
        if (!/^[A-Z]{4}[0-9]{3}$/.test(ma)) return alert("Mã phải có 4 chữ và 3 số!");
        try {
            const response = await fetch(GOOGLE_API + "?ma=" + ma);
            const txt = await response.text();
            if (txt === "Not Found") return alert("Không tìm thấy mã này!");
            const res = JSON.parse(txt);
            let db = JSON.parse(localStorage.getItem(DB) || '{}');
            db[res.n] = res.d;
            localStorage.setItem(DB, JSON.stringify(db));
            renderListProfile(); 
            loadProfile(res.n);
            alert("Đã tải xong: " + res.n);
        } catch (e) { alert('Lỗi kết nối hoặc mã sai.'); }
    }

    function hideCloudModal() { document.getElementById('cloudModal').classList.add('hidden'); }

    function luuProfile() {
        let n = document.getElementById('name').value.trim();
        if (!n) return alert("Nhập tên đã ông ơi!");
        let data = Array.from(document.querySelectorAll('.box')).map(b => ({
            attr: Array.from(b.querySelectorAll('.t')).map((t, i) => ({
                t: t.value,
                v: b.querySelectorAll('.v')[i].value
            })),
            cl: b.querySelector('.chatLuong')?.checked || false,
            tt: b.querySelector('.thuocTinh')?.checked || false
        }));
        let db = JSON.parse(localStorage.getItem(DB) || '{}');
        db[n] = data;
        localStorage.setItem(DB, JSON.stringify(db));
        renderListProfile();
        alert("✅ Đã tạo hồ sơ: " + n);
    }

function autoSave() {
    let n = document.getElementById('name').value.trim();
    if (!n) return;

    let data = Array.from(document.querySelectorAll('.box')).map(b => ({
        attr: Array.from(b.querySelectorAll('.t')).map((t, i) => ({
            t: t.value,
            v: b.querySelectorAll('.v')[i].value
        })),
        cl: b.querySelector('.chatLuong')?.checked || false,
        tt: b.querySelector('.thuocTinh')?.checked || false
    }));

    let db = JSON.parse(localStorage.getItem(DB) || '{}');
    db[n] = data; // Ghi đè dữ liệu mới vào đúng tên hồ sơ này
    localStorage.setItem(DB, JSON.stringify(db));
    
    // Chỉ cập nhật danh sách hiển thị, không vẽ lại toàn bộ giao diện để tránh lag
    renderListProfile();
}

    function loadProfile(n) {
        let db = JSON.parse(localStorage.getItem(DB) || '{}');
        if (!db[n]) return;
        document.getElementById('name').value = n;
        db[n].forEach((boxData, i) => {
            let b = document.querySelectorAll('.box')[i];
            if (!b) return;
            let attributes = boxData.attr ? boxData.attr : boxData;
            attributes.forEach((line, j) => {
                let select = b.querySelectorAll('.t')[j];
                if (![...select.options].some(o => o.value == line.t)) {
                    let opt = document.createElement('option'); opt.value = opt.text = line.t;
                    select.add(opt);
                }
                select.value = line.t;
                b.querySelectorAll('.v')[j].value = line.v;
            });
            if (boxData.attr) {
                if (b.querySelector('.chatLuong')) b.querySelector('.chatLuong').checked = boxData.cl;
                if (b.querySelector('.thuocTinh')) b.querySelector('.thuocTinh').checked = boxData.tt;
            }
        });
        calc();
    }

    function renderListProfile() {
        const listEl = document.getElementById('listProfile');
        if (!listEl) return;
        let db = JSON.parse(localStorage.getItem(DB) || '{}');
        listEl.innerHTML = Object.keys(db).map(n => `
            <div onmousedown="startTimer('${n}')" onmouseup="clearTimer()" onmouseleave="clearTimer()"
                 ontouchstart="startTimer('${n}')" ontouchend="clearTimer()"
                 onclick="loadProfile('${n}')" 
                 class="bg-zinc-800/50 p-1.5 px-3 rounded-lg cursor-pointer border border-zinc-800 text-[10px] text-zinc-400 hover:border-pink-500 hover:text-white transition-all italic select-none">
                ${n}
            </div>`).join('');
    }

    let pressTimer;
    function startTimer(name) {
        clearTimeout(pressTimer);
        pressTimer = window.setTimeout(() => {
            if (confirm(`Ông muốn xóa vĩnh viễn hồ sơ [${name}] này không?`)) {
                let db = JSON.parse(localStorage.getItem(DB) || '{}');
                delete db[name];
                localStorage.setItem(DB, JSON.stringify(db));
                renderListProfile();
            }
        }, 800);
    }
    function clearTimer() { clearTimeout(pressTimer); }

function saveToKho(index) {
    const slotName = slots[index];
    const box = document.querySelectorAll('.box')[index];
    const itemName = prompt(`Nhập tên lưu cho ${slotName}:`, `Đồ mới ${Date.now().toString().slice(-4)}`);
    
    if (!itemName) return;

    // Lấy tất cả các dòng (bao gồm 5 dòng thuộc tính + 1 dòng đá bổ trợ)
    const allSelects = box.querySelectorAll('.t');
    const allInputs = box.querySelectorAll('.v');

    const itemData = {
        name: itemName,
        // Lưu toàn bộ 6 dòng (5 thuộc tính + 1 đá)
        attr: Array.from(allSelects).map((sel, i) => ({
            t: sel.value,
            v: allInputs[i].value
        })),
        // Lưu trạng thái 2 checkbox đặc trưng của ông
        cl: box.querySelector('.chatLuong')?.checked || false,
        tt: box.querySelector('.thuocTinh')?.checked || false
    };

    if (!inventory[slotName]) inventory[slotName] = [];
    inventory[slotName].push(itemData);
    
    saveInventory(); // Lưu vào LocalStorage
    render();        // Cập nhật lại danh sách chọn ở màn hình chính
    alert(`Đã cất [${itemName}] vào kho!`);
}


function showKho() {
    const modal = document.getElementById('khoModal');
    const content = document.getElementById('khoContent');
    const total = document.getElementById('totalItems');
    
    // Nạp lại dữ liệu từ máy trước khi hiện
    loadInventory(); 

    modal.classList.remove('hidden');
    content.innerHTML = '';
    let count = 0;

    slots.forEach((s) => {
        const items = inventory[s] || [];
        if (items.length > 0) {
            let section = `<div class="mb-8 p-1">
                <div class="text-pink-400 font-extrabold text-[11px] uppercase tracking-wider mb-4 border-b-2 border-pink-900/40 pb-1.5 ml-1">
                    ● ${s.toUpperCase()} (${items.length} MÓN)
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">`;
            
            items.forEach((item, itemIdx) => {
                count++;
                
                // Lọc bỏ các dòng trống "---" để hiển thị
                const attrs = Array.isArray(item.attr) ? item.attr : [];
                const validAttrs = attrs.filter(a => a && a.t !== "---");

                // Tạo HTML cho phần chỉ số (dạng cột: Tên - %)
                let statsHtml = '';
                validAttrs.forEach(a => {
                    // Dòng chỉ số dạng cột: Tên bên trái, % bên phải
                    statsHtml += `
                        <div class="flex justify-between items-center text-[10px] leading-relaxed group">
                            <span class="text-zinc-400 group-hover:text-white transition-colors">${a.t}</span>
                            <b class="text-pink-400 font-bold ml-3 text-right">${a.v}%</b>
                        </div>`;
                });

                // Khối giao diện món đồ hoàn chỉnh (giống ảnh ông gửi)
                section += `
                    <div class="bg-zinc-200/40 p-5 rounded-2xl border border-zinc-700/60 flex flex-col justify-between hover:border-pink-500/50 transition-all hover:shadow-[0_0_15px_-3px_rgba(236,72,153,0.3)] hover:-translate-y-0.5">
                        <div class="mb-4 pr-1">
                            <div class="flex justify-between items-center gap-3 mb-4">
                                <b class="text-white text-[13px] font-extrabold truncate flex-1 tracking-tight">${item.name || 'Món đồ chưa đặt tên'}</b>
                                <div class="flex gap-1.5 shrink-0">
                                    <button onclick="loadFromKhoDirectly('${s}', ${itemIdx})" 
                                            class="bg-emerald-600/90 hover:bg-emerald-500 text-white text-[9px] font-bold px-3 py-1.5 rounded-lg transition-colors">
                                        MẶC
                                    </button>
                                    <button onclick="deleteFromKho('${s}', ${itemIdx})" 
                                            class="bg-red-600/90 hover:bg-red-500 text-white text-[9px] font-bold px-3 py-1.5 rounded-lg transition-colors">
                                        XÓA
                                    </button>
                                </div>
                            </div>
                            
                            <div class="space-y-1.5 border-t border-zinc-700/60 pt-3">
                                ${statsHtml || '<p class="text-[10px] text-zinc-600 italic">Món đồ này chưa có chỉ số.</p>'}
                            </div>
                        </div>

                        <div class="mt-auto pt-3 border-t border-zinc-700/50 flex items-center gap-4 text-[9px]">
                            <span class="text-pink-500/70 italic font-medium">Có thể Kế thừa:</span>
                            <label class="flex items-center gap-1.5 ${item.cl ? 'text-pink-400 font-bold' : 'text-zinc-600'}">
                                <span class="w-3.5 h-3.5 rounded border border-current flex items-center justify-center text-[8px]">${item.cl ? '✓' : ''}</span> 
                                CL
                            </label>
                            <label class="flex items-center gap-1.5 ${item.tt ? 'text-pink-400 font-bold' : 'text-zinc-600'}">
                                <span class="w-3.5 h-3.5 rounded border border-current flex items-center justify-center text-[8px]">${item.tt ? '✓' : ''}</span> 
                                TT
                            </label>
                        </div>
                    </div>`;
            });
            section += `</div></div>`;
            content.innerHTML += section;
        }
    });

    total.innerText = count;
    if (count === 0) content.innerHTML = '<p class="text-center text-zinc-500 italic py-10">Kho trống trơn ông ơi, đi farm đồ rồi lưu vào đây nhé!</p>';
}
  
function hideKho() { document.getElementById('khoModal').classList.add('hidden'); }

function loadFromKho(el) {
    const slotIdx = el.getAttribute('data-slot-index');
    const itemName = el.value;
    if (!itemName) return; 

    const slotName = slots[slotIdx];
    const item = inventory[slotName].find(i => i.name === itemName);
    
    if (item) {
        const box = document.querySelectorAll('.box')[slotIdx];
        const allSelects = box.querySelectorAll('.t');
        const allInputs = box.querySelectorAll('.v');

        // BỘ LỌC AN TOÀN: Lấy mảng an toàn
        const attrs = Array.isArray(item.attr) ? item.attr : [];

        attrs.forEach((line, j) => {
            if (line && j < allSelects.length) { 
                let select = allSelects[j];
                if (![...select.options].some(o => o.value == line.t)) {
                    let opt = document.createElement('option'); 
                    opt.value = opt.text = line.t;
                    select.add(opt);
                }
                select.value = line.t;
                allInputs[j].value = line.v || 0;
            }
        });
        
        if (box.querySelector('.chatLuong')) box.querySelector('.chatLuong').checked = item.cl || false;
        if (box.querySelector('.thuocTinh')) box.querySelector('.thuocTinh').checked = item.tt || false;
        
        calc();
    }
}

// HÀM MỚI NÀY ĐỂ XỬ LÝ NÚT 'LOAD' TRONG BẢNG KHO
function loadFromKhoDirectly(slotName, itemIdx) {
    const item = inventory[slotName][itemIdx];
    if (!item) return;

    // Tìm xem món đồ này nằm ở vị trí thứ mấy ngoài màn hình chính (Vũ khí=0, Áo=1...)
    const slotIdx = slots.indexOf(slotName);
    if (slotIdx === -1) return;

    const box = document.querySelectorAll('.box')[slotIdx];
    const allSelects = box.querySelectorAll('.t');
    const allInputs = box.querySelectorAll('.v');

    // Nạp lại 6 dòng thuộc tính
    const attrs = Array.isArray(item.attr) ? item.attr : [];
    attrs.forEach((line, j) => {
        if (j < allSelects.length) { 
            let select = allSelects[j];
            if (![...select.options].some(o => o.value == line.t)) {
                let opt = document.createElement('option'); 
                opt.value = opt.text = line.t;
                select.add(opt);
            }
            select.value = line.t;
            allInputs[j].value = line.v || 0;
        }
    });
    
    // Nạp lại trạng thái checkbox Chất lượng/Thuộc tính (Logic gốc của ông)
    if (box.querySelector('.chatLuong')) box.querySelector('.chatLuong').checked = item.cl || false;
    if (box.querySelector('.thuocTinh')) box.querySelector('.thuocTinh').checked = item.tt || false;
    
    // Tính toán lại tổng chỉ số ngoài màn hình chính
    calc(); 
    
    // Đóng bảng kho sau khi nạp
    hideKho(); 
    
    alert(`Đã nạp món [${item.name}] ra màn hình chính để sử dụng!`);
}

function deleteFromKho(slotName, itemIdx) {
    // Hỏi nhẹ một câu cho chắc cú kẻo xóa nhầm
    if (confirm(`Ông có chắc muốn vứt món [${inventory[slotName][itemIdx].name}] này đi không?`)) {
        inventory[slotName].splice(itemIdx, 1); // Xóa khỏi mảng
        saveInventory(); // Lưu lại vào máy
        showKho();       // Cập nhật lại giao diện bảng Kho đang mở
        render();        // Cập nhật lại mấy cái Dropdown bên ngoài màn hình chính
    }
}


    window.onload = () => { 
        loadInventory();
        render(); 
        renderListProfile();
    };
</script>
