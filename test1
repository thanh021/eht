    <style>
        body { background: #09090b; color: #fff; font-size: 11px; font-family: 'Lexend', sans-serif; }
        .card { background: #18181b; border: 1px solid #27272a; border-radius: 1rem; padding: 0.75rem; transition: 0.3s; }
        select, input { 
            background: #27272a; 
            border: 1px solid #3f3f46; 
            color: #fff; 
            border-radius: 0.6rem; 
            padding: 4px; 
            outline: none; 
            width: 100%; 
            font-size: 10px; 
        }
        .btn-p { 
            background: linear-gradient(135deg, #ec4899, #be185d); 
            padding: 6px 12px; 
            border-radius: 0.7rem; 
            font-weight: 800; 
            font-size: 9px; 
        }
        .tab-btn { 
            color: #71717a; 
            border-bottom: 2px solid transparent; 
            padding: 6px 10px; 
            font-weight: 600; 
            cursor: pointer; 
        }
        .tab-btn.active { 
            color: #ec4899; 
            border-color: #ec4899; 
        }
        .vk-select { 
            background: #311b92; 
            border: 1px solid #673ab7; 
            font-weight: bold; 
            color: #e1bee7; 
        }
        select { position: relative; z-index: 30 !important; }
        select:focus { z-index: 50 !important; box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.6); }
        .box { position: relative; z-index: 10; }
        optgroup { color: #ec4899; font-weight: bold; }
.box-content.hidden-node {
    display: none;
}
.btn-hide {
    cursor: pointer;
    transition: transform 0.2s;
}
.btn-hide.active {
    transform: rotate(-90deg);
}
    </style>
</head>
