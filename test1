  const uniqueEquip = {
    "Áo Giáp": {
        "Áo Choàng Lửa": [{t: "Tăng DEF", v: 15.5}, {t: "Kháng hiệu ứng", v: 10}, {t: "Phản sát thương", v: 0}],
