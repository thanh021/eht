    },
    "Mũ": {
        "Mũ Hoàng Gia": [{t: "Tăng ATK", v: 10}, {t: "Tăng DEF", v: 10}, {t: "Giảm hồi chiêu", v: 5}]
    }
};
   

    const daBoTroOptions = {
        "Vũ khí": ["---", "Đá Sát Thương", "Đá Chí Mạng", "Đá Boss", "Đá CRIT Damage", "Đá Bỏ Qua DEF", "Đá Tăng ATK %", "Đá Tăng HP %", "Đá Đặc Biệt 1", "Đá Đặc Biệt 2"],
        "Áo Giáp": ["---", "Đá DEF", "Đá HP", "Đá Kháng Hiệu Ứng"],
        "Găng tay": ["---", "Đá ATK", "Đá Chí Mạng"],
        "Giày": ["---", "Đá Tránh Né", "Đá Tốc Độ"],
        "Đai": ["---", "Đá HP", "Đá DEF"],
        "Nhẫn": ["---", "Đá ATK", "Đá CRIT"],
        "Dây chuyền": ["---", "Đá Sát Thương", "Đá Boss"],
        "Mũ": ["---", "Đá Chí Mạng", "Đá Kháng"]
    };

    function loadInventory() {
        inventory = JSON.parse(localStorage.getItem(INVENTORY_DB) || '{}');
        slots.forEach(s => { if (!Array.isArray(inventory[s])) inventory[s] = []; });
    }

    function saveInventory() {
        localStorage.setItem(INVENTORY_DB, JSON.stringify(inventory));
    }

    function render() {
        let h = '';
        let listChung = (curV === 'atk') ? chungATK : (curV === 'def' ? chungDEF : chungALL);
        slots.forEach((s, i) => {
            h += `<div class="card box relative z-10">
                <div class="flex justify-between items-center mb-3">
                    <b class="text-pink-400 uppercase italic text-[9px]">${s}</b>`;
       
if (s === "Vũ khí") {
    h += `<div class="flex gap-2">
        <select id="classSelect" onchange="changeClass(this.value)" class="vk-select !w-auto !py-0 h-5 text-[8px]">
            <option value="">-- CLASS --</option>
            ${Object.keys(classWeapons).map(cls => `<option value="${cls}">${cls}</option>`).join('')}
        </select>
        <select id="weaponSelect" onchange="autoFillWeapon(this.value)" class="vk-select !w-auto !py-0 h-5 text-[8px]">
            <option value="">-- VŨ KHÍ --</option>
        </select>
    </div>`;
} else if (uniqueEquip[s] && Object.keys(uniqueEquip[s]).length > 0) {
    // Tự động tạo Dropdown cho bất kỳ món nào có dữ liệu trong uniqueEquip
    h += `<select onchange="autoFillUnique(${i}, this.value)" class="vk-select !w-auto !py-0 h-5 text-[8px]">
        <option value="">-- ĐỒ ĐỘC NHẤT --</option>
        ${Object.keys(uniqueEquip[s]).map(itemName => `<option value="${itemName}">${itemName}</option>`).join('')}
    </select>`;
}
            h += `</div>
            <div class="flex gap-2 mb-3">
                <select class="inv-select flex-1 text-[8px]" data-slot-index="${i}" onchange="loadFromKho(this)">
                    <option value="">-- Kho ${s} --</option>
                    ${(inventory[s] || []).map(item => `<option value="${item.name}">${item.name}</option>`).join('')}
                </select>
                <button onclick="saveToKho(${i})" class="btn-p text-[8px] px-3 py-1">LƯU KHO</button>
            </div>
            <div class="text-pink-500/80 italic text-[9px] mb-1 ml-1">Thuộc tính</div>`;
            for (let row = 0; row < 5; row++) {
                h += `<div class="flex gap-2 mb-2">
                    <select class="t flex-[2.5]">${listChung.map(o => `<option value="${o}">${o}</option>`).join('')}</select>
                    <input type="number" class="v flex-[1] text-center font-bold" value="0">
                </div>`;
            }
            const daOptions = daBoTroOptions[s] || listChung;
            h += `<div class="mb-3">
                <div class="text-pink-500/80 italic text-[9px] mb-1 ml-1">Đá bổ trợ</div>
                <div class="flex gap-2">
                    <select class="t flex-[2.5]">${daOptions.map(o => `<option value="${o}">${o}</option>`).join('')}</select>
                    <input type="number" class="v flex-[1] text-center font-bold" value="0">
                </div>
            </div>
            <div class="mt-4 pt-2 border-t border-zinc-800/50 flex items-center gap-4 text-[9px]">
                <span class="text-pink-500/80 italic ml-1">Có thể Kế thừa:</span>
                <label class="flex items-center gap-1.5 cursor-pointer group">
                    <input type="checkbox" class="chatLuong accent-pink-500 w-3 h-3">
                    <span class="text-zinc-400 group-hover:text-white transition-colors">Chất lượng</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer group">
                    <input type="checkbox" class="thuocTinh accent-pink-500 w-3 h-3">
